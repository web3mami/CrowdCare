# Google Sign-In (Web client ID — no secret in the browser)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Optional: browser → RPC directly (only if the provider allows CORS). If unset, the app uses
# same-origin /api/solana-rpc (Vite proxy locally; Vercel serverless in production).
# VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Vercel (server only): upstream for /api/solana-rpc proxy. Optional.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Backend (Neon Postgres) — set on Vercel → Project → Settings → Environment Variables
# DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Run db/schema.sql in the Neon SQL editor once.
#
# Same value as VITE_GOOGLE_CLIENT_ID (server verifies POST /api/campaigns JWT `aud`).
# GOOGLE_CLIENT_ID=
#
# Local API + Vite: npx vercel dev (loads .env.local; DATABASE_URL + GOOGLE_CLIENT_ID required)
